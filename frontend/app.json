{
  "expo": {
    "name": "Latence",
    "slug": "latence-journal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "latence",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "owner": "atelier-benamer",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.atelierbenamer.latence",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Latence utilise la caméra pour les photos de souvenirs.",
        "NSPhotoLibraryUsageDescription": "Latence utilise la bibliothèque photo pour ajouter des souvenirs.",
        "NSMicrophoneUsageDescription": "Latence utilise le microphone pour les notes vocales et la transcription.",
        "CFBundleLocalizations": ["fr"],
        "CFBundleDevelopmentRegion": "fr"
      },
      "config": {
        "usesNonExemptEncryption": false
      },
      "associatedDomains": []
    },
    "android": {
      "package": "com.atelierbenamer.latence",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#F8F5F0"
      },
      "edgeToEdgeEnabled": true,
      "permissions": []
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F8F5F0"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/YOUR_EAS_PROJECT_ID"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
